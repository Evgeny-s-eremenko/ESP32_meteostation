// ============================================================
//  secrets.h.example — шаблон конфигурации
//
//  Скопируйте этот файл в secrets.h и заполните своими данными:
//    cp secrets.h.example secrets.h
//
//  secrets.h добавлен в .gitignore и НИКОГДА не попадёт в репозиторий.
// ============================================================
#pragma once

// ── WiFi ────────────────────────────────────────────────────
#define SECRET_WIFI_SSID        "your_wifi_ssid"
#define SECRET_WIFI_PASSWORD    "your_wifi_password"

// ── Веб-интерфейс (Basic Auth) ───────────────────────────────
#define SECRET_HTTP_USER        "REMOVED"
#define SECRET_HTTP_PASSWORD    "your_http_password"

// ── InfluxDB ─────────────────────────────────────────────────
#define SECRET_INFLUX_HOST       "your_influxdb_server_ip"
#define SECRET_INFLUX_PORT       "your_influxdb_server_port"
#define SECRET_INFLUX_DATABASE   "your_influxdb_database_name"


// ── NTP ──────────────────────────────────────────────────────
#define SECRET_NTP_SERVER       "pool.ntp.org"
#define SECRET_TZ_OFFSET_SEC    10800   // UTC+3 (Москва)
